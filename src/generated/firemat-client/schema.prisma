generator firemaatclient {
  provider = "prisma-client-js"
  output   = "../src/generated/firemat-client"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id       Int        @id @default(autoincrement())
  nombre   String
  Producto Producto[]
}

model Movimiento {
  id            Int      @id @default(autoincrement())
  tipo          String
  cantidad      Int
  stockAnterior Int
  stockNuevo    Int
  motivo        String?
  documento     String?
  createdAt     DateTime @default(now())
  productoId    Int
  userId        Int?
  Producto      Producto @relation(fields: [productoId], references: [id])
}

model Producto {
  id                       Int                        @id @default(autoincrement())
  nombre                   String
  descripcion              String?
  stock                    Int
  ubicacion                String?
  createdAt                DateTime                   @default(now())
  precio                   Float
  minStock                 Int                        @default(0)
  activo                   Boolean                    @default(true)
  criticidad               String                     @default("Media")
  imagen                   String?
  categoriaId              Int
  stockReservado           Int                        @default(0)
  sku                      String?                    @unique
  CotizacionFirematDetalle CotizacionFirematDetalle[]
  FunnelFirematOpportunity FunnelFirematOpportunity[]
  Movimiento               Movimiento[]
  Oportunidad              Oportunidad[]
  Categoria                Categoria                  @relation(fields: [categoriaId], references: [id])
  Venta                    Venta[]
  VentaDetalle             VentaDetalle[]
}

model Venta {
  id                 Int            @id @default(autoincrement())
  productoId         Int
  cliente            String
  contacto           String?
  cantidad           Int
  precio             Float
  total              Float
  estado             String         @default("PROSPECTO")
  responsable        String?
  fechaCierre        DateTime?
  createdAt          DateTime       @default(now())
  fechaProximaAccion DateTime?
  origen             String?
  probabilidad       Float?
  proximaAccion      String?
  Producto           Producto       @relation(fields: [productoId], references: [id])
  VentaDetalle       VentaDetalle[]
}

model VentaDetalle {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Int
  precio     Float
  subtotal   Float
  Producto   Producto @relation(fields: [productoId], references: [id])
  Venta      Venta    @relation(fields: [ventaId], references: [id])
}

model user {
  id        String   @id
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Cliente {
  id        Int     @id @default(autoincrement())
  nombre    String
  rut       String? @unique
  email     String?
  telefono  String?
  direccion String?

  razonSocial   String?             @map("razon_social")
  nombreEmpresa String?             @map("nombre_empresa")
  region        String?
  comuna        String?
  tipoCliente   TipoClienteFiremat?
  canalVenta    CanalVentaFiremat?  @map("canal_venta")
  activo        Boolean             @default(true)
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  contactos   ContactoClienteFiremat[]
  Oportunidad Oportunidad[]

  @@index([rut])
  @@index([nombre])
  @@index([razonSocial])
  @@index([activo])
  @@index([tipoCliente])
  @@index([canalVenta])
}

model Oportunidad {
  id                 Int       @id @default(autoincrement())
  clienteId          Int
  titulo             String
  descripcion        String?
  unidadNegocio      String
  estado             String    @default("PROSPECTO")
  etapa              String    @default("PROSPECTO")
  montoEstimado      Float?
  proximaAccion      String?
  fechaProximaAccion DateTime?
  probabilidad       Int?
  createdAt          DateTime  @default(now())
  productoId         Int?
  Cliente            Cliente   @relation(fields: [clienteId], references: [id])
  Producto           Producto? @relation(fields: [productoId], references: [id])
}

model CotizacionFiremat {
  id                       Int                        @id @default(autoincrement())
  cliente                  String
  contacto                 String?
  tipoCliente              String?
  responsable              String?
  estado                   String                     @default("BORRADOR")
  subtotal                 Float                      @default(0)
  descuento                Float                      @default(0)
  impuesto                 Float                      @default(0)
  total                    Float                      @default(0)
  fechaCotizacion          DateTime                   @default(now())
  fechaVencimiento         DateTime?
  fechaEnvio               DateTime?
  fechaSeguimiento         DateTime?
  fechaCierre              DateTime?
  probabilidadCierre       Int?
  comentariosCliente       String?
  objeciones               String?
  observaciones            String?
  motivoPerdida            String?
  motivoPostergacion       String?
  fechaReactivacion        DateTime?
  version                  Int                        @default(1)
  esActual                 Boolean                    @default(true)
  cotizacionBaseId         Int?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  numero                   String?                    @unique
  detalles                 CotizacionFirematDetalle[]
  FunnelFirematOpportunity FunnelFirematOpportunity[]
}

model CotizacionFirematDetalle {
  id              Int               @id @default(autoincrement())
  cotizacionId    Int
  productoId      Int
  cantidad        Int
  precioUnitario  Float
  descuentoPct    Float             @default(0)
  subtotal        Float
  stockDisponible Int?
  observacion     String?
  cotizacion      CotizacionFiremat @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto        Producto          @relation(fields: [productoId], references: [id])
}

model FunnelFirematOpportunity {
  id                         Int       @id @default(autoincrement())
  cliente                    String
  contacto                   String?
  telefono                   String?
  correo                     String?
  tipoCliente                String?
  rutEmpresa                 String?
  region                     String?
  comuna                     String?
  unidadNegocio              String?
  productoId                 Int?
  cantidadEstimada           Int?
  urgencia                   String?
  tipoUso                    String?
  necesidadSoporteTecnico    Boolean?
  alternativaProducto        String?
  comision                   Float?
  margenEstimado             Float?
  fechaComprometidaEnvio     DateTime?
  versionCotizacion          String?
  comentariosCliente         String?
  objeciones                 String?
  ordenCompra                String?
  correoAceptacion           String?
  condicionesComerciales     String?
  coordinacionAdministrativa String?
  estadoDocumentacion        String?
  traspasoAdministracion     Boolean?
  traspasoERP                Boolean?
  coordinacionDespacho       String?
  estadoComercialOrden       String?
  estadoDocumentacionVenta   String?
  responsable                String?
  etapa                      String    @default("PROSPECTO")
  montoEstimado              Float     @default(0)
  probabilidadCierre         Int?
  proximaAccion              String?
  fechaProximaAccion         DateTime?
  observaciones              String?
  origen                     String?
  estadoStock                String?
  cotizacionId               Int?
  motivoPerdida              String?
  motivoPostergacion         String?
  fechaReactivacion          DateTime?
  documentoRespaldo          String?
  fechaCierre                DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  probabilidad               Int?      @default(50)
  flujoPosterior             String?
  motivoDescarte             String?
  tipoBroker                 String?
  fechaEstimadaDespacho      DateTime?
  fechaSeguimientoPostventa  DateTime?
  nombreOportunidad          String?   @map("nombre_oportunidad")
  cargoContacto              String?   @map("cargo_contacto")
  direccionProyecto          String?   @map("direccion_proyecto")
  tipoOportunidad            String?   @map("tipo_oportunidad")
  fechaProbableCierre        DateTime? @map("fecha_probable_cierre")
  riesgoTecnico              String?   @map("riesgo_tecnico")
  comentariosInternos        String?   @map("comentarios_internos")
  observacionesTecnicas      String?   @map("observaciones_tecnicas")
  observacionCamposFaltantes String?   @map("observacion_campos_faltantes")
  lineaProducto              String?   @map("linea_producto") @db.VarChar(150)
  descuento                  Float?
  stockOportunidad           String?   @map("stock_oportunidad") @db.VarChar(20)
  reprogramacionesCount      Int       @default(0) @map("reprogramaciones_count")
  fechaUltimoCambioEtapa     DateTime? @map("fecha_ultimo_cambio_etapa")

  cotizacion      CotizacionFiremat?      @relation(fields: [cotizacionId], references: [id])
  producto        Producto?               @relation(fields: [productoId], references: [id])
  archivos        FunnelFirematArchivo[]
  historialEtapas HistorialEtapaFiremat[]
}

model ContactoClienteFiremat {
  id            Int     @id @default(autoincrement())
  clienteId     Int
  nombre        String
  cargo         String?
  telefono      String?
  correo        String?
  principal     Boolean @default(false)
  activo        Boolean @default(true)
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([correo])
  @@index([activo])
  @@map("contactos_cliente_firemat")
}

model FunnelFirematArchivo {
  id            Int      @id @default(autoincrement())
  oportunidadId Int
  tipo          String
  url           String
  publicId      String
  nombreArchivo String?
  mimeType      String?
  bytes         Int?
  etapa         String?
  observaciones String?
  createdAt     DateTime @default(now())

  oportunidad FunnelFirematOpportunity @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@index([oportunidadId])
  @@index([tipo])
  @@index([etapa])
  @@map("funnel_firemat_archivos")
}

model AlertaVistaFiremat {
  id        Int      @id @default(autoincrement())
  usuarioId String   @map("usuario_id") @db.Uuid
  alertaKey String   @map("alerta_key")
  vistoAt   DateTime @default(now()) @map("visto_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([usuarioId, alertaKey])
  @@index([usuarioId])
  @@index([alertaKey])
  @@map("alertas_vistas_firemat")
}

model HistorialEtapaFiremat {
  id            Int      @id @default(autoincrement())
  oportunidadId Int      @map("oportunidad_id")
  etapaAnterior String?  @map("etapa_anterior") @db.VarChar(100)
  etapaNueva    String   @map("etapa_nueva") @db.VarChar(100)
  usuarioId     String?  @map("usuario_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  oportunidad FunnelFirematOpportunity @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@index([oportunidadId])
  @@index([etapaNueva])
  @@index([createdAt])
  @@map("historial_etapas_firemat")
}

enum TipoClienteFiremat {
  cliente_final
  ferreteria
  broker
  redistribuidor
  instalador
  constructora
  otro
}

enum CanalVentaFiremat {
  venta_directa
  broker
  ferreteria
  redistribuidor
  instalador
  recompra
  otro
}
