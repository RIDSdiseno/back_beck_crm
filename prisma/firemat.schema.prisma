generator firemaatclient {
  provider = "prisma-client-js"
  output   = "../src/generated/firemat-client"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id       Int        @id @default(autoincrement())
  nombre   String
  Producto Producto[]
}

model Movimiento {
  id            Int      @id @default(autoincrement())
  tipo          String
  cantidad      Int
  stockAnterior Int
  stockNuevo    Int
  motivo        String?
  documento     String?
  createdAt     DateTime @default(now())
  productoId    Int
  userId        Int?
  Producto      Producto @relation(fields: [productoId], references: [id])
}

model Producto {
  id                       Int                        @id @default(autoincrement())
  nombre                   String
  descripcion              String?
  stock                    Int
  ubicacion                String?
  createdAt                DateTime                   @default(now())
  precio                   Float
  minStock                 Int                        @default(0)
  activo                   Boolean                    @default(true)
  criticidad               String                     @default("Media")
  imagen                   String?
  categoriaId              Int
  stockReservado           Int                        @default(0)
  sku                      String?                    @unique
  CotizacionFirematDetalle CotizacionFirematDetalle[]
  FunnelFirematOpportunity FunnelFirematOpportunity[]
  Movimiento               Movimiento[]
  Oportunidad              Oportunidad[]
  Categoria                Categoria                  @relation(fields: [categoriaId], references: [id])
  Venta                    Venta[]
  VentaDetalle             VentaDetalle[]
}

model Venta {
  id                 Int            @id @default(autoincrement())
  productoId         Int
  cliente            String
  contacto           String?
  cantidad           Int
  precio             Float
  total              Float
  estado             String         @default("PROSPECTO")
  responsable        String?
  fechaCierre        DateTime?
  createdAt          DateTime       @default(now())
  fechaProximaAccion DateTime?
  origen             String?
  probabilidad       Float?
  proximaAccion      String?
  Producto           Producto       @relation(fields: [productoId], references: [id])
  VentaDetalle       VentaDetalle[]
}

model VentaDetalle {
  id         Int      @id @default(autoincrement())
  ventaId    Int
  productoId Int
  cantidad   Int
  precio     Float
  subtotal   Float
  Producto   Producto @relation(fields: [productoId], references: [id])
  Venta      Venta    @relation(fields: [ventaId], references: [id])
}

model user {
  id        String   @id
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Cliente {
  id          Int           @id @default(autoincrement())
  nombre      String
  rut         String?       @unique
  email       String?
  telefono    String?
  direccion   String?
  createdAt   DateTime      @default(now())
  Oportunidad Oportunidad[]
}

model Oportunidad {
  id                 Int       @id @default(autoincrement())
  clienteId          Int
  titulo             String
  descripcion        String?
  unidadNegocio      String
  estado             String    @default("PROSPECTO")
  etapa              String    @default("PROSPECTO")
  montoEstimado      Float?
  proximaAccion      String?
  fechaProximaAccion DateTime?
  probabilidad       Int?
  createdAt          DateTime  @default(now())
  productoId         Int?
  Cliente            Cliente   @relation(fields: [clienteId], references: [id])
  Producto           Producto? @relation(fields: [productoId], references: [id])
}

model CotizacionFiremat {
  id                       Int                        @id @default(autoincrement())
  cliente                  String
  contacto                 String?
  tipoCliente              String?
  responsable              String?
  estado                   String                     @default("BORRADOR")
  subtotal                 Float                      @default(0)
  descuento                Float                      @default(0)
  impuesto                 Float                      @default(0)
  total                    Float                      @default(0)
  fechaCotizacion          DateTime                   @default(now())
  fechaVencimiento         DateTime?
  fechaEnvio               DateTime?
  fechaSeguimiento         DateTime?
  fechaCierre              DateTime?
  probabilidadCierre       Int?
  comentariosCliente       String?
  objeciones               String?
  observaciones            String?
  motivoPerdida            String?
  motivoPostergacion       String?
  fechaReactivacion        DateTime?
  version                  Int                        @default(1)
  esActual                 Boolean                    @default(true)
  cotizacionBaseId         Int?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  numero                   String?                    @unique
  detalles                 CotizacionFirematDetalle[]
  FunnelFirematOpportunity FunnelFirematOpportunity[]
}

model CotizacionFirematDetalle {
  id              Int               @id @default(autoincrement())
  cotizacionId    Int
  productoId      Int
  cantidad        Int
  precioUnitario  Float
  descuentoPct    Float             @default(0)
  subtotal        Float
  stockDisponible Int?
  observacion     String?
  cotizacion      CotizacionFiremat @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto        Producto          @relation(fields: [productoId], references: [id])
}

model FunnelFirematOpportunity {
  id                   Int                @id @default(autoincrement())
  cliente              String
  contacto             String?
  telefono             String?
  correo               String?
  tipoCliente          String?
  productoId           Int?
  cantidadEstimada     Int?
  responsable          String?
  etapa                String             @default("PROSPECTO")
  montoEstimado        Float              @default(0)
  probabilidadCierre   Int?
  proximaAccion        String?
  fechaProximaAccion   DateTime?
  observaciones        String?
  origen               String?
  estadoStock          String?
  cotizacionId         Int?
  motivoPerdida        String?
  motivoPostergacion   String?
  fechaReactivacion    DateTime?
  documentoRespaldo    String?
  fechaCierre          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  probabilidad         Int?               @default(50)
  cotizacion           CotizacionFiremat? @relation(fields: [cotizacionId], references: [id])
  producto             Producto?          @relation(fields: [productoId], references: [id])
}
