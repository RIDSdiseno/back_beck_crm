  @@map("permisos_rol_modulo")
}

model PermisoUsuarioModulo {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId   String   @map("usuario_id") @db.Uuid
  modulo      String   @db.VarChar(100)
  puedeVer    Boolean  @default(false) @map("puede_ver")
  puedeEditar Boolean  @default(false) @map("puede_editar")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, modulo])
  @@index([usuarioId])
  @@index([modulo])
  @@map("permisos_usuario_modulo")
}

model ObraTipoRegistro {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  obraId       String   @map("obra_id") @db.Uuid
  tipoRegistro String   @map("tipo_registro") @db.VarChar(50)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  obra         Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@unique([obraId, tipoRegistro])
  @@index([obraId])
  @@index([tipoRegistro])
  @@map("obra_tipos_registro")
}

// Tabla de tramos "holgura ≤ X → factor Y" editable por obra y tipo de registro.
// Reemplaza la tabla fija de calculosRegistroTerreno.ts para esa obra+tipo; si una
// obra no tiene tramos propios para un tipo, se usan los valores por defecto
// (getTramosHolguraPorDefecto). orden define la evaluación ascendente por holguraMax.
model FactorHolguraTramo {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  obraId       String   @map("obra_id") @db.Uuid
  tipoRegistro String   @map("tipo_registro") @db.VarChar(50)
  orden        Int
  holguraMax   Decimal  @map("holgura_max") @db.Decimal(6, 2)
  factor       Decimal  @db.Decimal(6, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  obra         Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@unique([obraId, tipoRegistro, orden])
  @@index([obraId])
  @@index([tipoRegistro])
  @@map("factor_holgura_tramos")
}

model ControlInspeccion {
  id                                                                String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  registroTerrenoId                                                 String                       @map("registro_terreno_id") @db.Uuid
  ingenieroId                                                       String                       @map("ingeniero_id") @db.Uuid
  fecha                                                             DateTime                     @db.Date
  ensayo                                                            String                       @db.VarChar(255)
  observacion                                                       String?
  conformidad                                                       EstadoConformidadInspeccion?
  fotoInspeccionUrl                                                 String?                      @map("foto_inspeccion_url")
  fotoNoConformidadUrl                                              String?                      @map("foto_no_conformidad_url")
  createdAt                                                         DateTime                     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                                                         DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  correccion_enviada_at                                             DateTime?                    @db.Timestamp(6)
  correccion_enviada_por_id                                         String?                      @db.Uuid
  ingeniero                                                         Usuario                      @relation("ControlesInspeccionPorUsuario", fields: [ingenieroId], references: [id])
  registroTerreno                                                   RegistroTerreno              @relation(fields: [registroTerrenoId], references: [id], onDelete: Cascade)
  usuarios_controles_inspeccion_correccion_enviada_por_idTousuarios Usuario?                     @relation("controles_inspeccion_correccion_enviada_por_idTousuarios", fields: [correccion_enviada_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_controles_inspeccion_correccion_enviada_por")
  parametros                                                        ControlInspeccionParametro[]
  fotos                                                             fotos_control_inspeccion[]

  @@index([registroTerrenoId])
  @@index([ingenieroId])
  @@index([fecha])
  @@index([conformidad])
  @@map("controles_inspeccion")
}

model ControlInspeccionParametro {
  id                         String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  controlInspeccionId        String                       @map("control_inspeccion_id") @db.Uuid
  orden                      Int
  parametro                  String                       @db.VarChar(500)
  resultado                  ResultadoParametroInspeccion
  observacion                String?
  createdAt                  DateTime                     @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                  DateTime                     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  correccion_observacion     String?
  corregido_at               DateTime?                    @db.Timestamp(6)
  corregido_por_id           String?                      @db.Uuid
  controlInspeccion          ControlInspeccion            @relation(fields: [controlInspeccionId], references: [id], onDelete: Cascade)
  usuarios                   Usuario?                     @relation(fields: [corregido_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_controles_inspeccion_parametros_corregido_por")
  fotos_correccion_parametro fotos_correccion_parametro[]

  @@index([controlInspeccionId])
  @@index([resultado])
  @@index([orden])
  @@map("controles_inspeccion_parametros")
}

model fotos_correccion_parametro {
  id                              String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  parametro_id                    String                     @db.Uuid
  url                             String
  public_id                       String                     @db.VarChar(255)
  nombre_archivo                  String?                    @db.VarChar(255)
  formato                         String?                    @db.VarChar(50)
  bytes                           Int?
  subido_por_id                   String?                    @db.Uuid
  created_at                      DateTime                   @default(now()) @db.Timestamp(6)
  controles_inspeccion_parametros ControlInspeccionParametro @relation(fields: [parametro_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_fotos_correccion_parametro_parametro")
  usuarios                        Usuario?                   @relation(fields: [subido_por_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_fotos_correccion_parametro_usuario")

  @@index([parametro_id], map: "idx_fotos_correccion_parametro_parametro_id")
  @@index([subido_por_id], map: "idx_fotos_correccion_parametro_subido_por_id")
}

