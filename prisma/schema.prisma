// ─── Estados de Avance ────────────────────────────────────────────────────────
// Hitos por obra. Cada hito muestra automáticamente TODOS los itemizados
// configurados de su obra; lo único propio del hito son sus cantidades
// (HitoObraCantidad, filas dispersas: solo existe fila cuando el usuario
// ingresó una cantidad). Código BECK / Itemizado BECK / Itemizado Mandante /
// PU / moneda NUNCA se copian aquí: se leen por join desde
// ConfiguracionItemizadoOpcionObra → ItemizadoOpcion.

model HitoObra {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  obraId         String    @map("obra_id") @db.Uuid
  nombre         String    @db.VarChar(255)
  orden          Int
  activo         Boolean   @default(true)
  terminado      Boolean   @default(false)
  terminadoAt    DateTime? @map("terminado_at") @db.Timestamp(6)
  terminadoPorId String?   @map("terminado_por_id") @db.Uuid
  // Período que representa el hito (Estado de Pago). Nullable a nivel de
  // columna para no romper hitos creados antes de este cambio ni forzar un
  // backfill en la migración; la API exige ambas fechas al crear un hito
  // nuevo — la obligatoriedad real vive en la validación, no en el schema.
  fechaDesde     DateTime? @map("fecha_desde") @db.Date
  fechaHasta     DateTime? @map("fecha_hasta") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  obra         Obra               @relation(fields: [obraId], references: [id], onDelete: Cascade)
  terminadoPor Usuario?           @relation("HitosTerminadosPorUsuario", fields: [terminadoPorId], references: [id])
  cantidades   HitoObraCantidad[]

  @@unique([obraId, orden])
  @@index([obraId])
  @@index([terminadoPorId])
  @@map("hitos_obra")
}

model HitoObraCantidad {
  id                           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hitoObraId                   String   @map("hito_obra_id") @db.Uuid
  configuracionItemizadoObraId String   @map("configuracion_itemizado_obra_id") @db.Uuid
  cantidadHito                 Decimal? @map("cantidad_hito") @db.Decimal(14, 2)
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  hitoObra                   HitoObra                         @relation(fields: [hitoObraId], references: [id], onDelete: Cascade)
  configuracionItemizadoObra ConfiguracionItemizadoOpcionObra @relation(fields: [configuracionItemizadoObraId], references: [id], onDelete: Cascade)

  @@unique([hitoObraId, configuracionItemizadoObraId])
  @@index([hitoObraId])
  @@index([configuracionItemizadoObraId])
  @@map("hitos_obra_cantidades")
}

