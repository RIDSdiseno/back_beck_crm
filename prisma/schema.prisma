generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id                    String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre                String                    @db.VarChar(255)
  email                 String                    @unique @db.VarChar(255)
  passwordHash          String?                   @map("password_hash") @db.VarChar(255)
  rol                   RolUsuario
  activo                Boolean                   @default(true)
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  azureId               String?                   @unique @map("azure_id") @db.VarChar(255)
  cotizacionesCreadas   Cotizacion[]              @relation("CotizacionesCreadasPorUsuario")
  fotos_registro        fotos_registro[]
  itemizadosCreados     Itemizado[]               @relation("ItemizadosCreadosPorUsuario")
  movimientosCrm        MovimientoCRM[]           @relation("MovimientosCrmPorUsuario")
  movimientosInventario MovimientoInventario[]
  notificaciones        Notificacion[]
  obrasCreadas          Obra[]                    @relation("ObrasCreadasPorUsuario")
  procesamientos        ProcesamientoIngenieria[]
  registrosTerreno      RegistroTerreno[]
  usuarios_obras        usuarios_obras[]

  @@index([email])
  @@index([rol])
  @@index([activo])
  @@map("usuarios")
}

model Obra {
  id                            String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre                        String                        @db.VarChar(255)
  codigo                        String?                       @unique @db.VarChar(100)
  descripcion                   String?
  estado                        EstadoObra                    @default(activa)
  creadoPorId                   String                        @map("creado_por_id") @db.Uuid
  createdAt                     DateTime                      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                     DateTime                      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  cliente                       String?                       @db.VarChar(255)
  direccion                     String?
  configuracionesCamposRegistro ConfiguracionCamposRegistro[]
  cotizaciones                  Cotizacion[]
  oportunidades                 OperadorBeck[]
  creadoPor                     Usuario                       @relation("ObrasCreadasPorUsuario", fields: [creadoPorId], references: [id])
  registrosTerreno              RegistroTerreno[]
  usuarios_obras                usuarios_obras[]

  @@index([codigo])
  @@index([estado])
  @@index([creadoPorId])
  @@map("obras")
}

model Itemizado {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  codigo         String                    @unique @db.VarChar(100)
  nombre         String                    @db.VarChar(255)
  descripcion    String?
  precioUnitario Decimal                   @default(0) @map("precio_unitario") @db.Decimal(12, 2)
  creadoPorId    String                    @map("creado_por_id") @db.Uuid
  createdAt      DateTime                  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  creadoPor      Usuario                   @relation("ItemizadosCreadosPorUsuario", fields: [creadoPorId], references: [id])
  procesamientos ProcesamientoIngenieria[]

  @@index([codigo])
  @@index([creadoPorId])
  @@map("itemizados")
}

model ItemizadoMandante {
  id          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  codigoBeck  String?           @map("codigo_beck") @db.VarChar(100)
  nombre      String            @db.VarChar(255)
  descripcion String?           @db.VarChar(500)
  activo      Boolean           @default(true)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  registros   RegistroTerreno[]

  @@map("itemizados_mandante")
}

model RegistroTerreno {
  id                        String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  obraId                    String                   @map("obra_id") @db.Uuid
  usuarioId                 String                   @map("usuario_id") @db.Uuid
  fecha                     DateTime                 @db.Date
  diaSemana                 String                   @map("dia_semana") @db.VarChar(20)
  descripcionMaterial       String                   @map("descripcion_material") @db.VarChar(500)
  modulo                    String                   @db.VarChar(100)
  piso                      String                   @db.VarChar(50)
  ejeNumerico               String                   @map("eje_numerico") @db.VarChar(50)
  ejeAlfabetico             String                   @map("eje_alfabetico") @db.VarChar(10)
  numeroSello               String                   @map("numero_sello") @db.VarChar(100)
  cantidadSellos            Int                      @map("cantidad_sellos")
  nombreSellador            String                   @map("nombre_sellador") @db.VarChar(255)
  holgura                   Decimal                  @db.Decimal(3, 1)
  accesibilidad             Int
  observaciones             String?
  fotosUrls                 String[]                 @map("fotos_urls")
  createdAt                 DateTime                 @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                 DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  estado                    EstadoRegistroTerreno    @default(pendiente)
  metrosLineales            Float?                   @map("metros_lineales")
  tipoRegistro              String                   @default("sello_cortafuego") @map("tipo_registro") @db.VarChar(50)
  itemizadoSacyr            String?                  @map("itemizado_sacyr") @db.VarChar(255)
  devuelto_a_tecnico        Boolean                  @default(false)
  codigoBeck                String?                  @map("codigo_beck")
  itemizadoMandanteId       String?                  @map("itemizado_mandante_id") @db.Uuid
  itemizadoBeck             String?                  @map("itemizado_beck") @db.VarChar(500)
  itemizadoMandanteTexto    String?                  @map("itemizado_mandante") @db.VarChar(255)
  fotoUrl                   String?                  @map("foto_url")
  recinto                   String?                  @db.VarChar(100)
  factorPorHolguras         Decimal?                 @map("factor_por_holguras") @db.Decimal(6, 2)
  cieloModular              Int?                     @map("cielo_modular")
  cantidadSellosConFactores Decimal?                 @map("cantidad_sellos_con_factores") @db.Decimal(12, 2)
  aislacion                 Decimal?                 @db.Decimal(6, 2)
  cantidadSellosAislacion   Decimal?                 @map("cantidad_sellos_aislacion") @db.Decimal(12, 2)
  reparacionTabique         Decimal?                 @map("reparacion_tabique") @db.Decimal(6, 2)
  cantidadFinal             Decimal?                 @map("cantidad_final") @db.Decimal(12, 2)
  folio                     String?                  @db.VarChar(100)
  fotos_registro            fotos_registro[]
  procesamiento             ProcesamientoIngenieria?
  itemizadoMandante         ItemizadoMandante?       @relation(fields: [itemizadoMandanteId], references: [id])
  obra                      Obra                     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  usuario                   Usuario                  @relation(fields: [usuarioId], references: [id])

  @@index([obraId])
  @@index([itemizadoMandanteId])
  @@index([usuarioId])
  @@index([fecha(sort: Desc)])
  @@index([estado])
  @@index([tipoRegistro])
  @@index([devuelto_a_tecnico])
  @@map("registros_terreno")
}

model ProcesamientoIngenieria {
  id                   String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  registroTerrenoId    String          @unique @map("registro_terreno_id") @db.Uuid
  usuarioId            String          @map("usuario_id") @db.Uuid
  codigo               String?         @db.VarChar(100)
  itemizadoId          String?         @map("itemizado_id") @db.Uuid
  totalSellosCalculado Decimal?        @map("total_sellos_calculado") @db.Decimal(12, 2)
  notas                String?
  procesadoAt          DateTime        @default(now()) @map("procesado_at") @db.Timestamp(6)
  itemizado            Itemizado?      @relation(fields: [itemizadoId], references: [id])
  registroTerreno      RegistroTerreno @relation(fields: [registroTerrenoId], references: [id], onDelete: Cascade)
  usuario              Usuario         @relation(fields: [usuarioId], references: [id])

  @@index([registroTerrenoId])
  @@index([usuarioId])
  @@index([itemizadoId])
  @@map("procesamiento_ingenieria")
}

model Notificacion {
  id           String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId    String           @map("usuario_id") @db.Uuid
  tipo         TipoNotificacion
  referenciaId String?          @map("referencia_id") @db.Uuid
  mensaje      String
  leido        Boolean          @default(false)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  usuario      Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([leido])
  @@index([createdAt(sort: Desc)])
  @@map("notificaciones")
}

model Inventario {
  id             String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  codigoProducto String                 @unique @map("codigo_producto") @db.VarChar(100)
  nombre         String                 @db.VarChar(255)
  descripcion    String?
  stockActual    Int                    @default(0) @map("stock_actual")
  stockMinimo    Int                    @default(0) @map("stock_minimo")
  ubicacion      String?                @db.VarChar(255)
  createdAt      DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  movimientos    MovimientoInventario[]

  @@index([codigoProducto])
  @@index([stockActual])
  @@map("inventario")
}

model MovimientoInventario {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  productoId      String         @map("producto_id") @db.Uuid
  tipo            TipoMovimiento
  cantidad        Int
  usuarioId       String         @map("usuario_id") @db.Uuid
  codigoEscaneado String?        @map("codigo_escaneado") @db.VarChar(255)
  observaciones   String?
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  producto        Inventario     @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuario         Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([usuarioId])
  @@index([createdAt(sort: Desc)])
  @@map("movimientos_inventario")
}

model Cotizacion {
  id               String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  obraId           String?              @map("obra_id") @db.Uuid
  estado           EstadoCotizacion     @default(BORRADOR)
  creadoPorId      String               @map("creado_por_id") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamp(6)
  numero           String?              @db.VarChar(50)
  descuento        Decimal              @default(0) @db.Decimal(12, 2)
  subtotal         Decimal              @db.Decimal(12, 2)
  total            Decimal              @db.Decimal(12, 2)
  clienteNombre    String               @map("cliente_nombre") @db.VarChar(255)
  observaciones    String?
  vigencia         DateTime             @db.Timestamp(6)
  impuesto         Decimal              @default(0) @db.Decimal(12, 2)
  aplicaImpuesto   Boolean              @default(true)
  funnelBeckId     String?              @map("funnel_beck_id") @db.Uuid
  cotizacionBaseId String?              @map("cotizacion_base_id") @db.Uuid
  esActual         Boolean              @default(true) @map("es_actual")
  version          Int                  @default(1)
  clienteBeckId    String?              @map("cliente_beck_id") @db.Uuid
  contactoBeckId   String?              @map("contacto_beck_id") @db.Uuid
  clienteBeck      ClienteBeck?         @relation(fields: [clienteBeckId], references: [id])
  contactoBeck     ContactoClienteBeck? @relation(fields: [contactoBeckId], references: [id])
  cotizacionBase   Cotizacion?          @relation("HistorialCotizaciones", fields: [cotizacionBaseId], references: [id])
  versiones        Cotizacion[]         @relation("HistorialCotizaciones")
  creadoPor        Usuario              @relation("CotizacionesCreadasPorUsuario", fields: [creadoPorId], references: [id])
  funnelBeck       OperadorBeck?        @relation(fields: [funnelBeckId], references: [id])
  obra             Obra?                @relation(fields: [obraId], references: [id])
  lineas           LineaCotizacion[]

  @@unique([numero, version])
  @@index([clienteNombre])
  @@index([estado])
  @@index([obraId])
  @@index([funnelBeckId])
  @@index([creadoPorId])
  @@index([numero])
  @@index([version])
  @@index([esActual])
  @@index([cotizacionBaseId])
  @@index([clienteBeckId])
  @@index([contactoBeckId])
  @@map("cotizaciones")
}

model LineaCotizacion {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cotizacionId      String              @map("cotizacion_id") @db.Uuid
  descripcion       String
  cantidad          Decimal             @db.Decimal(10, 3)
  precioUnitario    Decimal             @map("precio_unitario") @db.Decimal(12, 2)
  subtotal          Decimal             @db.Decimal(12, 2)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)
  gananciaPct       Decimal             @default(0) @map("ganancia_pct") @db.Decimal(6, 2)
  notasLinea        String?             @map("notas_linea")
  orden             Int                 @default(0)
  tipoLinea         TipoLineaCotizacion @default(PRODUCTO) @map("tipo_linea")
  unidad            String?             @db.VarChar(50)
  productoFirematId Int?                @map("producto_firemat_id")
  cotizacion        Cotizacion          @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@map("lineas_cotizacion")
}

model OperadorBeck {
  id                                  String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombreProyecto                      String                    @map("nombre_proyecto") @db.VarChar(255)
  empresa                             String                    @db.VarChar(255)
  valorOriginal                       Decimal                   @map("valor_original") @db.Decimal(14, 2)
  monedaOriginal                      MonedaFunnel              @map("moneda_original")
  valorClp                            Decimal                   @map("valor_clp") @db.Decimal(14, 2)
  valorUf                             Decimal                   @map("valor_uf") @db.Decimal(14, 4)
  fechaProbableCierre                 DateTime                  @map("fecha_probable_cierre") @db.Date
  vendedor                            String                    @db.VarChar(255)
  region                              String                    @db.VarChar(150)
  comuna                              String                    @db.VarChar(150)
  fuenteLead                          FuenteLeadFunnel?
  etapa                               EtapaFunnelBeck           @default(prospecto_identificado)
  estadoCierre                        EstadoCierreFunnel?
  motivoPerdida                       String?                   @map("motivo_perdida")
  createdAt                           DateTime                  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt                           DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  dolarValor                          Decimal?                  @map("dolar_valor") @db.Decimal(12, 4)
  fechaTipoCambio                     DateTime?                 @map("fecha_tipo_cambio") @db.Timestamp(6)
  ufValor                             Decimal?                  @map("uf_valor") @db.Decimal(12, 4)
  ajustesSolicitados                  String?                   @map("ajustes_solicitados")
  cargoContacto                       String?                   @map("cargo_contacto") @db.VarChar(120)
  contrapropuestas                    String?
  correoContacto                      String?                   @map("correo_contacto") @db.VarChar(255)
  documentoRespaldo                   String?                   @map("documento_respaldo")
  etapaPerdida                        String?                   @map("etapa_perdida") @db.VarChar(100)
  fechaPrimerContacto                 DateTime?                 @map("fecha_primer_contacto") @db.Date
  fechaProximaAccion                  DateTime?                 @map("fecha_proxima_accion") @db.Date
  fechaReactivacion                   DateTime?                 @map("fecha_reactivacion") @db.Date
  flujoPosterior                      String?                   @map("flujo_posterior")
  motivoPostergacion                  String?                   @map("motivo_postergacion")
  necesidadDetectada                  String?                   @map("necesidad_detectada")
  nivelInteres                        String?                   @map("nivel_interes") @db.VarChar(50)
  nombreContacto                      String?                   @map("nombre_contacto") @db.VarChar(255)
  objeciones                          String?
  probabilidadCierre                  Int?                      @map("probabilidad_cierre")
  proximaAccion                       String?                   @map("proxima_accion")
  rutEmpresa                          String?                   @map("rut_empresa") @db.VarChar(20)
  telefonoContacto                    String?                   @map("telefono_contacto") @db.VarChar(50)
  timingEstimado                      String?                   @map("timing_estimado") @db.VarChar(100)
  tipoCliente                         String?                   @map("tipo_cliente") @db.VarChar(100)
  tipoContacto                        String?                   @map("tipo_contacto") @db.VarChar(100)
  tipoOportunidad                     String?                   @map("tipo_oportunidad") @db.VarChar(100)
  clienteBeckId                       String?                   @map("cliente_beck_id") @db.Uuid
  contactoBeckId                      String?                   @map("contacto_beck_id") @db.Uuid
  antecedentesLevantados              String?                   @map("antecedentes_levantados")
  anticipo                            String?
  aprobacionInternaCliente            String?                   @map("aprobacion_interna_cliente")
  asistentes                          String?
  basesTecnicas                       String?                   @map("bases_tecnicas")
  comentariosCliente                  String?                   @map("comentarios_cliente")
  comentariosInternos                 String?                   @map("comentarios_internos")
  condicionesEspeciales               String?                   @map("condiciones_especiales")
  condicionesPago                     String?                   @map("condiciones_pago")
  contrato                            String?
  correoAceptacion                    String?                   @map("correo_aceptacion")
  documentosAdministrativosPendientes String?                   @map("documentos_administrativos_pendientes")
  documentosRecibidos                 String?                   @map("documentos_recibidos")
  documentosRequeridos                String?                   @map("documentos_requeridos")
  especificaciones                    String?
  estadoDesarrolloPropuesta           String?                   @map("estado_desarrollo_propuesta")
  fechaCierre                         DateTime?                 @map("fecha_cierre") @db.Date
  fechaComprometidaEnvio              DateTime?                 @map("fecha_comprometida_envio") @db.Date
  fechaEnvioPropuesta                 DateTime?                 @map("fecha_envio_propuesta") @db.Date
  fechaFirma                          DateTime?                 @map("fecha_firma") @db.Date
  fechaInicioProyecto                 DateTime?                 @map("fecha_inicio_proyecto") @db.Date
  fechaVencimientoPropuesta           DateTime?                 @map("fecha_vencimiento_propuesta") @db.Date
  fechaVisita                         DateTime?                 @map("fecha_visita") @db.Date
  fotografias                         String?
  informacionPendiente                String?                   @map("informacion_pendiente")
  lugarVisita                         String?                   @map("lugar_visita")
  montoFinalGanado                    Decimal?                  @map("monto_final_ganado") @db.Decimal(14, 2)
  montoPropuesto                      Decimal?                  @map("monto_propuesto") @db.Decimal(14, 2)
  necesidadOficinaTecnica             Boolean?                  @map("necesidad_oficina_tecnica")
  necesidadValidacionGerencial        Boolean?                  @map("necesidad_validacion_gerencial")
  numeroPropuesta                     String?                   @map("numero_propuesta") @db.VarChar(100)
  observacionesTecnicas               String?                   @map("observaciones_tecnicas")
  ordenCompra                         String?                   @map("orden_compra")
  planos                              String?
  proximosPasos                       String?                   @map("proximos_pasos")
  responsableAdministrativo           String?                   @map("responsable_administrativo") @db.VarChar(255)
  responsableTecnico                  String?                   @map("responsable_tecnico") @db.VarChar(255)
  riesgoTecnico                       String?                   @map("riesgo_tecnico") @db.VarChar(50)
  versionPropuesta                    String?                   @map("version_propuesta") @db.VarChar(50)
  obraId                              String?                   @map("obra_id") @db.Uuid
  fechaTraspasoAdministracion         DateTime?                 @map("fecha_traspaso_administracion") @db.Date
  fechaTraspasoOperaciones            DateTime?                 @map("fecha_traspaso_operaciones") @db.Date
  observacionesTraspasoAdministracion String?                   @map("observaciones_traspaso_administracion")
  observacionesTraspasoOperaciones    String?                   @map("observaciones_traspaso_operaciones")
  responsableTraspasoAdministracion   String?                   @map("responsable_traspaso_administracion") @db.VarChar(255)
  responsableTraspasoOperaciones      String?                   @map("responsable_traspaso_operaciones") @db.VarChar(255)
  traspasadoAdministracion            Boolean?                  @map("traspasado_administracion")
  traspasadoOperaciones               Boolean?                  @map("traspasado_operaciones")
  cotizaciones                        Cotizacion[]
  clienteBeck                         ClienteBeck?              @relation(fields: [clienteBeckId], references: [id])
  contactoBeck                        ContactoClienteBeck?      @relation(fields: [contactoBeckId], references: [id])
  obra                                Obra?                     @relation(fields: [obraId], references: [id])
  archivos                            FunnelBeckArchivo[]
  solicitudesOficinaTecnica           SolicitudOficinaTecnica[]

  @@index([etapa])
  @@index([estadoCierre])
  @@index([fechaProbableCierre])
  @@index([empresa])
  @@index([vendedor])
  @@index([region])
  @@index([comuna])
  @@index([clienteBeckId])
  @@index([contactoBeckId])
  @@index([obraId])
  @@map("funnel_beck")
}

model IndicadorEconomico {
  id        String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tipo      TipoIndicadorEconomico @unique
  valor     Decimal                @db.Decimal(12, 4)
  fecha     DateTime               @db.Timestamp(6)
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("indicadores_economicos")
}

model usuarios_obras {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuario_id  String   @db.Uuid
  obra_id     String   @db.Uuid
  asignado_en DateTime @default(now()) @db.Timestamp(6)
  obras       Obra     @relation(fields: [obra_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuarios_obras_obra")
  usuarios    Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_usuarios_obras_usuario")

  @@unique([usuario_id, obra_id], map: "uq_usuarios_obras")
  @@index([obra_id], map: "idx_usuarios_obras_obra_id")
  @@index([usuario_id], map: "idx_usuarios_obras_usuario_id")
}

model MovimientoCRM {
  id          String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId   String              @map("usuario_id") @db.Uuid
  modulo      ModuloMovimientoCRM
  tipo        TipoMovimientoCRM
  entidadId   String?             @map("entidad_id") @db.Uuid
  descripcion String
  datos       Json?
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  usuario     Usuario             @relation("MovimientosCrmPorUsuario", fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([modulo])
  @@index([tipo])
  @@index([entidadId])
  @@index([createdAt(sort: Desc)])
  @@map("movimientos_crm")
}

model fotos_registro {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  registro_id       String          @db.Uuid
  url               String
  public_id         String          @db.VarChar(255)
  nombre_archivo    String?         @db.VarChar(255)
  formato           String?         @db.VarChar(50)
  bytes             Int?
  subido_por_id     String?         @db.Uuid
  created_at        DateTime        @default(now()) @db.Timestamp(6)
  registros_terreno RegistroTerreno @relation(fields: [registro_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_fotos_registro_registro")
  usuarios          Usuario?        @relation(fields: [subido_por_id], references: [id], onUpdate: NoAction, map: "fk_fotos_registro_usuario")

  @@index([registro_id], map: "idx_fotos_registro_registro_id")
  @@index([subido_por_id], map: "idx_fotos_registro_subido_por_id")
}

model ClienteBeck {
  id            String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rut           String                @unique @db.VarChar(20)
  razonSocial   String                @map("razon_social") @db.VarChar(255)
  direccion     String?
  telefono      String?               @db.VarChar(50)
  correo        String?               @db.VarChar(255)
  region        String?               @db.VarChar(150)
  comuna        String?               @db.VarChar(150)
  tipoCliente   String?               @map("tipo_cliente") @db.VarChar(100)
  origen        String?               @db.VarChar(100)
  activo        Boolean               @default(true)
  observaciones String?
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  nombreEmpresa String?               @map("nombre_empresa") @db.VarChar(255)
  contactos     ContactoClienteBeck[]
  cotizaciones  Cotizacion[]
  oportunidades OperadorBeck[]

  @@index([rut])
  @@index([razonSocial])
  @@index([activo])
  @@map("clientes_beck")
}

model ContactoClienteBeck {
  id            String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clienteId     String         @map("cliente_id") @db.Uuid
  nombre        String         @db.VarChar(255)
  cargo         String?        @db.VarChar(120)
  telefono      String?        @db.VarChar(50)
  correo        String?        @db.VarChar(255)
  principal     Boolean        @default(false)
  activo        Boolean        @default(true)
  observaciones String?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  cliente       ClienteBeck    @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  cotizaciones  Cotizacion[]
  oportunidades OperadorBeck[]

  @@index([clienteId])
  @@index([correo])
  @@index([activo])
  @@map("contactos_cliente_beck")
}

model FunnelBeckArchivo {
  id            String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  oportunidadId String            @map("oportunidad_id") @db.Uuid
  tipo          TipoArchivoFunnel
  url           String
  publicId      String            @map("public_id")
  nombreArchivo String?           @map("nombre_archivo")
  mimeType      String?           @map("mime_type")
  bytes         Int?
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamp(6)
  oportunidad   OperadorBeck      @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@index([oportunidadId])
  @@index([tipo])
  @@map("funnel_beck_archivos")
}

model SolicitudOficinaTecnica {
  id                     String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  oportunidadId          String                        @map("oportunidad_id") @db.Uuid
  estado                 EstadoSolicitudOficinaTecnica @default(pendiente)
  responsableComercial   String?                       @map("responsable_comercial") @db.VarChar(255)
  responsableTecnico     String?                       @map("responsable_tecnico") @db.VarChar(255)
  antecedentesLevantados String?                       @map("antecedentes_levantados")
  basesTecnicas          String?                       @map("bases_tecnicas")
  especificaciones       String?
  observacionesTecnicas  String?                       @map("observaciones_tecnicas")
  comentariosRevision    String?                       @map("comentarios_revision")
  fechaSolicitud         DateTime                      @default(now()) @map("fecha_solicitud") @db.Timestamp(6)
  fechaRevision          DateTime?                     @map("fecha_revision") @db.Timestamp(6)
  createdAt              DateTime                      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime                      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  oportunidad            OperadorBeck                  @relation(fields: [oportunidadId], references: [id], onDelete: Cascade)

  @@index([oportunidadId])
  @@index([estado])
  @@index([responsableTecnico])
  @@index([fechaSolicitud])
  @@map("solicitudes_oficina_tecnica")
}

model ConfiguracionCamposRegistro {
  id              Int      @id @default(autoincrement())
  campo           String
  rol             String
  visible         Boolean  @default(true)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  obraId          String   @map("obra_id") @db.Uuid
  obra            Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@unique([obraId, rol, campo])
  @@index([obraId])
  @@map("configuracion_campos_registro")
}

